---
import { themes, themeIds } from '../data/themes';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">Side Software Co</p>
      <p class="footer-copyright">&copy; {year}</p>
      {
        themeIds
          .filter((id) => themes[id].copy.footerTagline)
          .map((id) => (
            <p class="footer-tagline" data-theme-content={id}>
              {themes[id].copy.footerTagline}
            </p>
          ))
      }
    </div>
    <nav class="footer-links" aria-label="Footer">
      <a
        href="https://github.com/side-software"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      <a
        href="https://github.com/ogc-maps"
        target="_blank"
        rel="noopener noreferrer">ogc-maps</a
      >
      <a href="mailto:christopher.esterlein@gmail.com">Contact</a>
    </nav>
  </div>
  <div class="corporate-badges" aria-hidden="true">
    <div class="corporate-badge">
      <span class="corporate-badge-icon">&#128274;</span>
      <span>SOC 2 Compliant</span>
    </div>
    <div class="corporate-badge">
      <span class="corporate-badge-icon">&#9989;</span>
      <span>ISO 27001</span>
    </div>
    <div class="corporate-badge">
      <span class="corporate-badge-icon">&#127942;</span>
      <span>Gartner Recognized</span>
    </div>
    <div class="corporate-badge">
      <span class="corporate-badge-icon">&#9201;</span>
      <span>99.99% Uptime SLA</span>
    </div>
  </div>
  <div class="geo-counter" aria-hidden="true">
    &#9658; You are visitor #00004,782
  </div>
  <div class="geo-construction" aria-hidden="true">
    &#128679; UNDER CONSTRUCTION - CHECK BACK SOON!! &#128679;
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-2xl) 0;
    color: var(--color-text-subtle);
    font-size: 0.85rem;
    transition: border-color var(--transition-slow);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer-name {
    font-weight: 600;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .footer-copyright {
    color: var(--color-text-subtle);
    margin-top: var(--space-xs);
  }

  .footer-tagline {
    color: var(--color-text-subtle);
    font-size: 0.75rem;
    margin-top: var(--space-xs);
    font-style: italic;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-links a {
    color: var(--color-text-subtle);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 639px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
