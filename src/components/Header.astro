---
import Logo from './Logo.astro';
import ThemePicker from './ThemePicker.astro';
---

<div class="geo-marquee" aria-hidden="true">
  <span
    >&#9733; &#9733; &#9733; Welcome to Side Software!! The BEST software
    company on the World Wide Web!! &#9733; &#9733; &#9733; Click around and
    check out all the cool stuff!! &#9733; &#9733; &#9733;</span
  >
</div>
<div class="corporate-banner" aria-hidden="true">
  Trusted by forward-thinking organizations worldwide
</div>
<header class="site-header">
  <div class="container header-inner">
    <nav aria-label="Primary">
      <Logo />
    </nav>
    <ThemePicker />
  </div>
</header>

<style>
  .site-header {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-slow);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
  }

  @media (max-width: 480px) {
    .header-inner {
      flex-wrap: wrap;
    }
  }
</style>
