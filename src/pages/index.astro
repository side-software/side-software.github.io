---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkipToContent from '../components/SkipToContent.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Footer from '../components/Footer.astro';
import { themes, themeIds } from '../data/themes';

const title = 'Side Software Co';
const description =
  'Affordable, production-grade software through AI-accelerated delivery. Cloud-native geospatial specialty.';

const stack = [
  'React',
  'Astro',
  'PostgreSQL',
  'PostGIS',
  'OGC APIs',
  'MapLibre',
  'Terraform',
  'AWS / GCP',
  'STAC',
];
---

<BaseLayout title={title} description={description}>
  <SkipToContent />
  <Header />

  <main id="main-content">
    <Hero />

    <section class="section animate-on-scroll">
      <div class="container">
        {
          themeIds.map((id) => (
            <div data-theme-content={id}>
              <p class="section-label">
                {themes[id].copy.sectionLabels.services}
              </p>
              <h2>{themes[id].copy.sectionHeadings.services}</h2>
              <div class="services-grid">
                {themes[id].copy.services.map((s) => (
                  <ServiceCard title={s.title} description={s.description} />
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        {
          themeIds.map((id) => (
            <div class="prose" data-theme-content={id}>
              <p class="section-label">
                {themes[id].copy.sectionLabels.howItWorks}
              </p>
              <h2>{themes[id].copy.sectionHeadings.howItWorks}</h2>
              {themes[id].copy.howItWorks.map((para) => (
                <p set:html={para} />
              ))}
            </div>
          ))
        }
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        {
          themeIds.map((id) => (
            <div data-theme-content={id}>
              <p class="section-label">
                {themes[id].copy.sectionLabels.stack}
              </p>
              <h2>{themes[id].copy.sectionHeadings.stack}</h2>
              <p class="stack-intro">{themes[id].copy.stackIntro}</p>
            </div>
          ))
        }
        <ul class="stack-list">
          {stack.map((tech) => <li class="stack-pill">{tech}</li>)}
        </ul>
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        {
          themeIds.map((id) => (
            <div class="prose" data-theme-content={id}>
              <p class="section-label">
                {themes[id].copy.sectionLabels.contact}
              </p>
              <h2>{themes[id].copy.sectionHeadings.contact}</h2>
              <p set:html={themes[id].copy.contactText} />
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .section {
    padding: var(--space-4xl) 0;
  }

  h2 {
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  /* Services grid */
  .services-grid {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Stack pills */
  .stack-intro {
    color: var(--color-text-muted);
  }

  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    list-style: none;
  }

  .stack-pill {
    padding: var(--space-xs) 0.75rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    animation: var(--pill-animation, none);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .stack-pill:hover {
    background-color: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
    box-shadow: 0 0 12px var(--color-glow);
  }

  /* Responsive spacing */
  @media (max-width: 639px) {
    .section {
      padding: var(--space-2xl) 0;
    }
  }
</style>
