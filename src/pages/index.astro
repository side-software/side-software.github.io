---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkipToContent from '../components/SkipToContent.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Footer from '../components/Footer.astro';

const title = 'Side Software Co';
const description =
  'Affordable, production-grade software through AI-accelerated delivery. Cloud-native geospatial specialty.';

const services = [
  {
    title: 'Geospatial systems',
    description:
      'Interactive web maps, spatial APIs, and data pipelines built on OGC standards. We deliver the database, the API, the viewer, and the infrastructure as a managed bundle.',
  },
  {
    title: 'Custom software',
    description:
      "Websites, internal tools, and data architecture for businesses that need something off-the-shelf can't provide. Modern stack, built to last.",
  },
  {
    title: 'AI workflow consulting',
    description:
      'We help engineering teams adopt AI-accelerated development with reusable skills, automated verification, and structured agent orchestration.',
  },
];

const stack = [
  'React',
  'Astro',
  'PostgreSQL',
  'PostGIS',
  'OGC APIs',
  'MapLibre',
  'Terraform',
  'AWS / GCP',
  'STAC',
];
---

<BaseLayout title={title} description={description}>
  <SkipToContent />
  <Header />

  <main id="main-content">
    <Hero />

    <section class="section animate-on-scroll">
      <div class="container">
        <p class="section-label">// 01</p>
        <h2>What we build</h2>
        <div class="services-grid">
          {
            services.map((s) => (
              <ServiceCard title={s.title} description={s.description} />
            ))
          }
        </div>
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        <div class="prose">
          <p class="section-label">// 02</p>
          <h2>How it works</h2>
          <p>
            The &ldquo;affordable&rdquo; part isn&rsquo;t about cutting corners.
            It&rsquo;s about an opinionated operating model that combines AI
            tooling with open-source foundations and DevOps discipline, so a
            small team ships what used to require a large one.
          </p>
          <p>
            Our geospatial work builds on
            <a href="https://github.com/ogc-maps">ogc-maps</a>, an open-source
            organization we maintain with reusable mapping libraries built
            around OGC API standards. Customers pay for delivery and support,
            not R&D.
          </p>
        </div>
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        <p class="section-label">// 03</p>
        <h2>Stack</h2>
        <p class="stack-intro">
          Cloud-native, standards-based, and built for maintainability.
        </p>
        <ul class="stack-list">
          {stack.map((tech) => <li class="stack-pill">{tech}</li>)}
        </ul>
      </div>
    </section>

    <section class="section animate-on-scroll">
      <div class="container">
        <div class="prose">
          <p class="section-label">// 04</p>
          <h2>Get in touch</h2>
          <p>
            Interested in working together? Reach out at
            <a href="mailto:christopher.esterlein@gmail.com"
              >christopher.esterlein@gmail.com</a
            >.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .section {
    padding: var(--space-4xl) 0;
  }

  h2 {
    font-size: 1.35rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  /* Services grid */
  .services-grid {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 640px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Stack pills */
  .stack-intro {
    color: var(--color-text-muted);
  }

  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    list-style: none;
  }

  .stack-pill {
    padding: var(--space-xs) 0.75rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .stack-pill:hover {
    background-color: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
    box-shadow: 0 0 12px var(--color-glow);
  }

  /* Responsive spacing */
  @media (max-width: 639px) {
    .section {
      padding: var(--space-2xl) 0;
    }
  }
</style>
